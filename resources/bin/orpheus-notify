#!/bin/bash
set -u
EVENT="${1:-}"
[ -z "$EVENT" ] && exit 0
[ -z "${ORPHEUS_SOCK:-}" ] && exit 0
[ -z "${ORPHEUS_WORKSPACE_ID:-}" ] && exit 0
[ -S "$ORPHEUS_SOCK" ] || exit 0

PAYLOAD="{}"
if [ ! -t 0 ]; then
  PAYLOAD="$(cat 2>/dev/null || echo '{}')"
  [ -z "$PAYLOAD" ] && PAYLOAD="{}"
fi

curl --unix-socket "$ORPHEUS_SOCK" -fsS -o /dev/null --max-time 2 \
  -X POST \
  -H "Content-Type: application/json" \
  -H "X-Workspace-ID: $ORPHEUS_WORKSPACE_ID" \
  -H "X-Event: $EVENT" \
  --data-binary "$PAYLOAD" \
  "http://localhost/notify" 2>/dev/null || true

exit 0
