#!/bin/bash
# Orpheus CLI shim — runs the bundled CLI under Electron-as-Node.
#
# This script ships at Contents/Resources/bin/orpheus and is prepended to
# PATH in every workspace terminal (ORPHEUS_USER_PATH injection). It resolves
# the Electron binary and the CLI bundle relative to its own location so the
# paths are correct in both packaged and dev builds.
#
# Layout (packaged):
#   Contents/
#     MacOS/
#       Orpheus             ← Electron binary
#     Resources/
#       app.asar.unpacked/
#         node_modules/
#           better-sqlite3/ ← native module (unpacked from asar by electron-builder)
#       bin/
#         orpheus           ← this script
#       cli/
#         cli.js            ← bundled CLI
#
# Layout (dev, after bun run build:dev installs Orpheus Dev.app):
#   Contents/
#     MacOS/
#       Orpheus Dev         ← Electron binary
#     Resources/
#       app.asar.unpacked/
#         node_modules/
#           better-sqlite3/ ← native module (same layout as prod)
#       bin/
#         orpheus           ← this script
#       cli/
#         cli.js            ← bundled CLI
#
# NODE_PATH for better-sqlite3
# ----------------------------
# The CLI bundle externalizes better-sqlite3 so the native .node addon can be
# loaded at runtime. However, cli.js lives at Resources/cli/cli.js — it has no
# node_modules ancestor containing better-sqlite3. We must point Node at the
# unpacked location via NODE_PATH before exec'ing the bundle.
#
# electron-builder's asarUnpack extracts native modules (matching '**/*.node')
# to Resources/app.asar.unpacked/. The canonical location is therefore:
#   Resources/app.asar.unpacked/node_modules/
#
# We try that path first, then fall back to a sibling Resources/node_modules/
# in case a future layout change moves things. NODE_PATH is additive — we
# prepend so our path is searched first, with any existing NODE_PATH appended.

set -eu

# Resolve the directory containing this script, following symlinks.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

# The Resources dir is one level up from bin/.
RESOURCES_DIR="$(dirname "$SCRIPT_DIR")"

# The MacOS dir is a sibling of Resources/.
MACOS_DIR="$(dirname "$RESOURCES_DIR")/MacOS"

# The bundled CLI lives at Resources/cli/cli.js.
CLI_BUNDLE="$RESOURCES_DIR/cli/cli.js"

# Locate the native module directory and set NODE_PATH.
# Primary: Resources/app.asar.unpacked/node_modules (standard electron-builder asarUnpack layout)
# Fallback: Resources/node_modules (non-asar dev layout, future-proofing)
UNPACKED_NM="$RESOURCES_DIR/app.asar.unpacked/node_modules"
SIBLING_NM="$RESOURCES_DIR/node_modules"

if [ -d "$UNPACKED_NM" ]; then
  ORPHEUS_NODE_PATH="$UNPACKED_NM"
elif [ -d "$SIBLING_NM" ]; then
  ORPHEUS_NODE_PATH="$SIBLING_NM"
else
  ORPHEUS_NODE_PATH=""
fi

# Prepend to existing NODE_PATH (may be unset — guard with :- default).
if [ -n "$ORPHEUS_NODE_PATH" ]; then
  export NODE_PATH="$ORPHEUS_NODE_PATH${NODE_PATH:+:${NODE_PATH}}"
fi

# Find the Electron binary: prefer "Orpheus Dev" (dev build), fall back to "Orpheus".
if [ -x "$MACOS_DIR/Orpheus Dev" ]; then
  ELECTRON_BIN="$MACOS_DIR/Orpheus Dev"
elif [ -x "$MACOS_DIR/Orpheus" ]; then
  ELECTRON_BIN="$MACOS_DIR/Orpheus"
else
  echo "orpheus: error: cannot find Electron binary in $MACOS_DIR" >&2
  echo "  Expected 'Orpheus Dev' or 'Orpheus' — is the app bundle intact?" >&2
  exit 1
fi

if [ ! -f "$CLI_BUNDLE" ]; then
  echo "orpheus: error: CLI bundle not found at $CLI_BUNDLE" >&2
  echo "  Run 'bun run build:cli' to build the bundle." >&2
  exit 1
fi

# Run the CLI bundle under Electron's bundled Node runtime. The env var must be
# exported before exec — `exec VAR=val cmd` would try to exec "VAR=val" itself.
export ELECTRON_RUN_AS_NODE=1
exec "$ELECTRON_BIN" "$CLI_BUNDLE" "$@"
