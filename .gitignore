node_modules
dist
out
.DS_Store
.eslintcache
*.log*
vendor/
packages/*/build/
# Rust artifacts (kept generic for any future addon — terminal-vt-native
# was the only consumer and has been removed)
packages/*/target/
packages/*/*.node
# .claude/agents and .claude/commands ARE tracked; only the per-dispatch
# worktree clones (each one contains a .git pointer file that would otherwise
# be added as a submodule) are ignored.
.claude/worktrees/
# Scheduler runtime lockfile written by Claude Code wake-up tasks
.claude/scheduled_tasks.lock
# TypeScript incremental build cache
*.tsbuildinfo
# Stray bundle extracts (e.g. from asar debugging) — never commit these
/index-*.js
# Release artifacts — generated by scripts/release.mjs / CI, never tracked
release-notes.md
tmp/
# Local planning/session artifacts — contain machine-specific paths
docs/superpowers/
