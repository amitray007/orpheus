{
  "name": "orpheus",
  "version": "0.4.0",
  "private": true,
  "description": "A Mac IDE built around Claude Code",
  "author": "Amit Ray <hey@amitray.dev>",
  "license": "SEE LICENSE IN LICENSE",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "bun run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && bash scripts/fetch-libghostty.sh",
    "install:mac": "node scripts/install-mac.mjs --dev",
    "install:mac-prod": "node scripts/install-mac.mjs",
    "build:native": "node scripts/build-native.mjs",
    "build:unpack": "bun run build:dev",
    "build:dev": "bun run build:native && ORPHEUS_MODE=development bun run build && bunx electron-builder --config electron-builder-dev.yml --dir && bun run install:mac",
    "build:win": "bun run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac && bun run install:mac-prod",
    "build:linux": "electron-vite build && electron-builder --linux",
    "fetch:libghostty": "bash scripts/fetch-libghostty.sh",
    "bump:libghostty": "bun scripts/bump-libghostty.mjs",
    "diag": "bun scripts/diag.ts",
    "release": "node scripts/release.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,jsx,json,yml,yaml,md,css,html}": "prettier --write"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@floating-ui/react": "^0.27.19",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@phosphor-icons/react": "^2.1.10",
    "@web-kits/audio": "^0.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "geist": "^1.7.0",
    "minidenticons": "^4.2.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
