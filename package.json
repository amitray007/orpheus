{
  "name": "orpheus",
  "version": "0.5.3",
  "private": true,
  "description": "A Mac IDE built around Claude Code",
  "author": "Amit Ray <hey@amitray.dev>",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "bun@1.3.10",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amitray007/orpheus.git"
  },
  "homepage": "https://github.com/amitray007/orpheus#readme",
  "bugs": {
    "url": "https://github.com/amitray007/orpheus/issues"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "doctor": "react-doctor",
    "doctor:ci": "react-doctor --scope changed --no-score --no-color",
    "lint": "eslint --cache .",
    "check:arch": "depcruise src packages/orpheus-cli --config .dependency-cruiser.cjs",
    "check:dup": "jscpd",
    "check:dead": "knip",
    "check": "bun run typecheck && bun run lint && bun run check:dup && bun run check:arch",
    "test:db": "node --experimental-strip-types scripts/verify-migration-engine.ts",
    "test:flags": "node --experimental-strip-types scripts/verify-cli-flags.ts",
    "test:workbench": "bun run scripts/verify-workbench-reducer.ts",
    "test:models": "bun run scripts/verify-model-registry.ts",
    "test:routing": "bun run scripts/verify-routing.ts",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "bun run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && bash scripts/fetch-libghostty.sh",
    "install:mac": "node scripts/install-mac.mjs --dev",
    "install:mac-wt": "node scripts/install-mac.mjs --wt",
    "install:mac-prod": "node scripts/install-mac.mjs",
    "build:native": "node scripts/build-native.mjs",
    "build:unpack": "bun run build:dev",
    "build:cli": "bunx esbuild packages/orpheus-cli/src/cli.ts --bundle --platform=node --format=cjs --external:better-sqlite3 --external:electron --outfile=packages/orpheus-cli/dist/cli.cjs",
    "build:dev": "bun run build:native && bun run build:cli && ORPHEUS_MODE=development bun run build && GOMAXPROCS=1 bunx electron-builder --config electron-builder-dev.yml --dir && bun run install:mac",
    "build:wt": "bun run build:native && ORPHEUS_MODE=worktree bun run build && GOMAXPROCS=1 bunx electron-builder --config electron-builder-wt.yml --dir && bun run install:mac-wt",
    "build:mac": "bun run build:native && bun run build:cli && electron-vite build && GOMAXPROCS=1 electron-builder --mac && bun run install:mac-prod",
    "fetch:libghostty": "bash scripts/fetch-libghostty.sh",
    "bump:libghostty": "bun scripts/bump-libghostty.mjs",
    "diag": "bun scripts/diag.ts",
    "release": "node scripts/release.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --cache --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,jsx,json,yml,yaml,md,css,html}": "prettier --write"
  },
  "dependencies": {
    "@codemirror/commands": "6.10.4",
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/lang-python": "6.2.1",
    "@codemirror/language": "6.12.4",
    "@codemirror/search": "6.7.1",
    "@codemirror/state": "6.7.0",
    "@codemirror/view": "6.43.5",
    "@electron-toolkit/utils": "^4.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "@pierre/diffs": "1.2.12",
    "@pierre/theme": "1.1.0",
    "@pierre/trees": "1.0.0-beta.5",
    "@tanstack/react-table": "^8.21.3",
    "@web-kits/audio": "^0.1.0",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "geist": "^1.7.0",
    "markdown-it": "^14.3.0",
    "minidenticons": "^4.2.1",
    "motion": "^12.42.2",
    "radix-ui": "^1.6.2",
    "recharts": "3.8.0",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.2.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "dependency-cruiser": "^18.0.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-sonarjs": "^4.1.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.11",
    "knip": "^6.24.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.3",
    "react": "^19.2.1",
    "react-doctor": "^0.6.0",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "overrides": {
    "@babel/core": "7.29.6",
    "esbuild": "0.28.1",
    "form-data": "4.0.6",
    "js-yaml": "4.2.0",
    "postcss": "8.5.14",
    "tar": "7.5.16",
    "tmp": "0.2.7",
    "undici": "6.27.0"
  }
}
