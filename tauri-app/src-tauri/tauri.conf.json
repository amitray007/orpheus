{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OrpheusTauriSpike",
  "identifier": "com.orpheus.taurispike",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Orpheus Tauri Spike",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/icon.png"
    ]
  }
}
