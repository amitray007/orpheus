{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Orpheus main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "shell:default",
    "dialog:default",
    "autostart:default",
    "global-shortcut:default"
  ]
}
